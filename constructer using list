class CIRCLE:
    def __init__(self):
        x=int(input("Enter the radius:"))
        self.radius=x
    def display(self):
        print("Area of Circle:",3.14*self.radius**2)


a =int(input("Enter the no of circles:"))
circles=[]
for i in range(a):
    c=CIRCLE()
    circles.append(c)
    c.display()
    print("_____________________")
